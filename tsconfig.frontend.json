{
  "compilerOptions": {
    "rootDir": "./src/frontend",
    "outDir": "./dist/frontend",

    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",

    "lib": ["ES2020", "DOM"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": ["src/frontend/**/*"],
  "exclude": ["node_modules", "dist"]
}