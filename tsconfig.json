{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",

    "types": ["node"],
    "lib": ["ES2020", "DOM"],

    "strict": true,
    "esModuleInterop": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "skipLibCheck": true,

    //"sourceMap": true

  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}